# Vidya Hub Frontend — Environment Variables

# ── API URL ──────────────────────────────────────────────
# Used by the Vite dev server (web / mobile development only).
# Port 5001 = PostgreSQL backend for web/mobile dev.
#
# ⚠️  DO NOT change this for desktop testing.
#     sync-and-test.sh and build.sh automatically pass
#     VITE_API_URL=/api at build time so the desktop app
#     always calls the backend it is served from.
VITE_API_URL=http://localhost:5001/api
