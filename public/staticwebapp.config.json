{
  "navigationFallback": {
    "rewrite": "/index.html",
    "exclude": [
      "/assets/*",
      "/favicon.ico"
    ]
  },
  "routes": [
    {
      "route": "/assets/*"
    },
    {
      "route": "/*",
      "rewrite": "/index.html"
    }
  ],
  "globalHeaders": {
    "Cache-Control": "no-cache"
  }
}